<div class="beavers-lore-wizard standard-form" style="padding:1rem">

  <p style="margin-top:0">
    <i class="fas fa-folder"></i> <strong>{{locationName}}</strong> contains both
    subfolders and journals. Which should be treated as chapters?
  </p>

  <div style="display:flex;gap:1.5rem;margin-bottom:1rem">
    <div style="flex:1">
      <p style="margin:0 0 .4rem;font-weight:bold;font-size:.875em">
        Folders ({{mixedFolders.length}})
      </p>
      <ul style="margin:0;padding-left:1.2rem;font-size:.875em">
        {{#each mixedFolders}}
          <li><i class="fas fa-folder" style="opacity:.6"></i> {{name}}</li>
        {{/each}}
      </ul>
    </div>
    <div style="flex:1">
      <p style="margin:0 0 .4rem;font-weight:bold;font-size:.875em">
        Journals ({{mixedJournals.length}})
      </p>
      <ul style="margin:0;padding-left:1.2rem;font-size:.875em">
        {{#each mixedJournals}}
          <li><i class="fas fa-book" style="opacity:.6"></i> {{name}}</li>
        {{/each}}
      </ul>
    </div>
  </div>

  <div style="display:flex;flex-direction:column;gap:.5rem;margin-bottom:1.25rem">
    <button type="button" data-action="useMixedFolders" style="width:100%">
      <i class="fas fa-folder"></i> Use Folders as Chapters
    </button>
    <button type="button" data-action="useMixedJournals" style="width:100%">
      <i class="fas fa-book"></i> Use Journals as Chapters
    </button>
    <button type="button" data-action="useMixedBoth" style="width:100%">
      <i class="fas fa-layer-group"></i> Use Both as Chapters
    </button>
  </div>

  <div style="display:flex;justify-content:flex-start">
    <button type="button" data-action="backToStatus">
      <i class="fas fa-arrow-left"></i> Back
    </button>
  </div>

</div>