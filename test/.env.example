FOUNDRY_URL=http://localhost:30000

# Get these from the module settings: Settings → Beavers AI Assistant → Connection Info
FOUNDRY_USER=
FOUNDRY_PASS=

# Optional: paste your browser session cookie here to skip login entirely.
# Get it from the browser console: document.cookie
FOUNDRY_COOKIE=

# Set to true to log all incoming socket events for debugging.
DEBUG=false
