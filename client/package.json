{
  "name": "beavers-voice-transcript-client",
  "version": "1.0.1",
  "description": "Client library for the Beavers AI Assistant Foundry VTT module",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "beavers-client": "./dist/cli.js"
  },
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "socket.io-client": "^4.8.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AngryBeaver/beavers-voice-transcript"
  },
  "keywords": [
    "foundry-vtt",
    "foundryvtt",
    "beavers"
  ],
  "license": "MIT"
}
